# ── Rate-limit zone for the admin login (brute-force protection) ──
# Lives in the http context — valid here because sites-enabled is included
# inside http{} in nginx.conf. Keyed by client IP; ~5 requests/minute.
limit_req_zone $binary_remote_addr zone=login:10m rate=5r/m;
# Scan ingestion: all stations share one NAT IP (the event hotspot), and a
# dense pack can post a burst of detections, so this is deliberately generous
# (~5 req/s sustained, burst 100) — it never throttles a real event but caps
# volumetric abuse. The API key is the real lock; this is defence in depth.
limit_req_zone $binary_remote_addr zone=scan:10m rate=300r/m;
limit_req_status 429;

# ── HTTP :80 — ACME challenge + redirect everything else to HTTPS ──
server {
    listen 80;
    listen [::]:80;
    server_name spendenlauf.taskminder.de;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS :443 — the application ──
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name spendenlauf.taskminder.de;

    # SSL (managed by Certbot)
    ssl_certificate     /etc/letsencrypt/live/spendenlauf.taskminder.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/spendenlauf.taskminder.de/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    server_tokens off;
    client_max_body_size 2m; # scan payloads are tiny

    # ── Security headers ──
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options    "nosniff" always;
    add_header X-Frame-Options           "DENY" always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
    # CSP: app uses Leaflet (CDN) + OpenStreetMap tiles + an external foot-router.
    # Tighten the host lists to exactly what HTML loads.
    add_header Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' https://unpkg.com; \
        style-src 'self' 'unsafe-inline' https://unpkg.com; \
        img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; \
        connect-src 'self' https://routing.openstreetmap.de https://*.fossgis.de; \
        font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'" always;

    error_page 413 = @payload_too_large;
    location @payload_too_large {
        default_type text/plain;
        return 413 "NGINX request size limit exceeded";
    }

    # Shared proxy settings (inherited by the locations below).
    proxy_set_header Host              $host;
    proxy_set_header X-Forwarded-Host  $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_read_timeout 120;

    # Throttle login attempts: ~5/min steady, allowing a small burst of 5.
    location = /api/login {
        limit_req zone=login burst=5 nodelay;
        proxy_pass http://127.0.0.1:8000;
    }

    # Cap scan ingestion volume (see zone=scan comment above).
    location = /api/scan {
        limit_req zone=scan burst=100 nodelay;
        proxy_pass http://127.0.0.1:8000;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
    }
}
