# Admin login for the Spendenlauf dashboard.
# Copy file to ".env" and change the values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=abc1234
# Session cookie is HTTPS-only by default. For local HTTP development
# (and the simulator over http://localhost) set this to false.
# Leave it unset / true in production behind HTTPS.
COOKIE_SECURE=true
# Pre-shared key the ESP32 stations send as the X-API-Key header on
# /api/scan, /api/beacons/whitelist and /api/station/config. Must match
# STATION_API_KEY in the firmware. Generate one with:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Required — ingestion fails closed (HTTP 503) if this is unset.
STATION_API_KEY=changeme-station-key
